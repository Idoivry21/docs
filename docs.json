{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hearflow",
  "colors": {
    "primary": "#0284C7",
    "light": "#38BDF8",
    "dark": "#075985"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "getting-started"]
          },
          {
            "group": "Meetings",
            "pages": [
              "integrations/zoom",
              "integrations/google-meet",
              "integrations/fireflies",
              "integrations/granola",
              "integrations/fathom"
            ]
          },
          {
            "group": "Messaging",
            "pages": ["integrations/slack", "integrations/gmail"]
          },
          {
            "group": "Productivity",
            "pages": [
              "integrations/notion",
              "integrations/asana",
              "integrations/clickup",
              "integrations/hubspot",
              "integrations/zendesk"
            ]
          },
          {
            "group": "Upload",
            "pages": [
              "integrations/google-sheets",
              "integrations/tally",
              "integrations/csv-upload",
              "integrations/manual-upload"
            ]
          },
          {
            "group": "Insights & Workspace",
            "pages": ["insights", "settings", "team", "billing"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api/overview", "api/authentication"]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.yaml"
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://hearflow.io/support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://hearflow.io/login"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/hearflow",
      "linkedin": "https://linkedin.com/company/hearflow"
    }
  },
  "favicon": "/images/HF-logo-blue-face.png",
  "logo": "/logos/HF-logo-blue-face.png",
  "background": {
    "color": {
      "light": "#f6f9f9"
    },
    "decoration": "grid"
  }
}
